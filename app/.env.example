CF_CALLS_APP_ID=your_cloudflare_calls_app_id
CF_CALLS_APP_SECRET=your_cloudflare_calls_app_secret
VITE_ROOM_SERVER_URL=ws://localhost:8787
OPENAI_API_KEY=your_openai_api_key
# Optional: faster/cheaper default is gpt-4o-mini; use gpt-4o for stronger replies
#AGENT_CHAT_MODEL=gpt-4o-mini
#AGENT_MAX_TOKENS=200
# TTS speed (0.25–4), default ~1.25; use OpenAI speech speed, not browser playback (avoids chipmunk pitch)
#AGENT_TTS_SPEED=1.25
